#!/bin/sh
# A dmenu wrapper script for system functions.
case "$(readlink -f /sbin/init)" in
	*systemd*) ctl='systemctl' ;;
	*) ctl='loginctl' ;;
esac

case "$(printf "’ĆŻ lock\n’ĪĖ display off\n’Īé logout\n’łČ sleep\n’Ć× reboot\n’Ćæ shutdown" | dmenu -i -p 'Action: ')" in
	'’ĆŻ lock') slock ;;
	'’ĪĖ display off') xset dpms force off ;;
	'’Īé logout') kill -TERM "$(pgrep -u "$USER" "\bdwm$")" ;;
	'’łČ sleep') slock $ctl suspend ;;
	'’Ć× reboot') $ctl reboot ;;
	'’Ćæ shutdown') $ctl poweroff ;;
	*) exit 1 ;;
esac
